---
import { Icon } from "astro-icon/components";
import { getCategoryList } from "../utils/content-utils";
import { url } from "../utils/url-utils";

interface Props {
	total: number;
}

const { total } = Astro.props;
const categoryCount = (await getCategoryList()).length;
---

<section class="home-overview card-base onload-animation" aria-labelledby="home-overview-title">
	<div class="home-overview-copy">
		<p>KEMOU / HOME</p>
		<h1 id="home-overview-title">最近更新</h1>
		<div class="home-overview-stats">
			<span>{total} 篇记录</span>
			<i aria-hidden="true"></i>
			<span>{categoryCount} 个分类</span>
		</div>
	</div>

	<nav class="home-overview-actions" aria-label="首页快捷入口">
		<a class="home-action" href={url("/archive/")}>
			<Icon name="material-symbols:inventory-2-outline-rounded" />
			<span>归档</span>
		</a>
		<a class="home-action" href={url("/rss.xml")} target="_blank">
			<Icon name="fa6-solid:rss" />
			<span>RSS</span>
		</a>
	</nav>
</section>

<style>
	.home-overview {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 8.5rem;
		margin-bottom: 1rem;
		padding: 1.25rem 1.4rem;
		overflow: visible;
	}

	.home-overview-copy p {
		margin: 0 0 0.2rem;
		font-size: 0.65rem;
		font-weight: 800;
		letter-spacing: 0.16em;
		color: var(--primary);
	}

	.home-overview-copy h1 {
		margin: 0;
		font-size: clamp(1.65rem, 4vw, 2.25rem);
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: -0.035em;
		color: rgb(23 23 23 / 0.92);
	}

	:global(:root.dark) .home-overview-copy h1 {
		color: rgb(250 250 250 / 0.92);
	}

	.home-overview-stats {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		margin-top: 0.7rem;
		font-size: 0.75rem;
		font-weight: 650;
		color: rgb(115 115 115);
	}

	:global(:root.dark) .home-overview-stats {
		color: rgb(163 163 163);
	}

	.home-overview-stats i {
		width: 0.25rem;
		aspect-ratio: 1;
		border-radius: 50%;
		background: var(--primary);
	}

	.home-overview-actions {
		display: flex;
		gap: 0.85rem;
	}

	.home-action {
		display: grid;
		place-items: center;
		width: 4.5rem;
		aspect-ratio: 1;
		border: 1px solid var(--neu-border);
		border-radius: 1.2rem;
		color: var(--btn-content);
		background: color-mix(in srgb, var(--card-bg) 94%, transparent);
		backdrop-filter: blur(10px);
		box-shadow: 6px 6px 13px var(--neu-shadow), -5px -5px 11px var(--neu-highlight), inset 1px 1px 0 var(--neu-inset-highlight);
		transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 200ms ease, color 180ms ease;
	}

	.home-action :global(svg) {
		width: 1.3rem;
		height: 1.3rem;
	}

	.home-action span {
		margin-top: -0.85rem;
		font-size: 0.68rem;
		font-weight: 750;
	}

	.home-action:hover,
	.home-action:focus-visible {
		color: var(--primary);
		transform: translateY(-2px) scale(1.018);
		box-shadow: 8px 8px 16px var(--neu-shadow-strong), -6px -6px 13px var(--neu-highlight-strong);
	}

	.home-action:active {
		transform: translateY(1px);
		box-shadow: inset 4px 4px 8px var(--neu-inset-shadow), inset -4px -4px 8px var(--neu-inset-highlight);
	}

	@media (max-width: 640px) {
		.home-overview {
			min-height: 7rem;
			padding: 1rem 1.1rem;
		}

		.home-overview-actions { gap: 0.55rem; }
		.home-action { width: 3.65rem; border-radius: 1rem; }
		.home-action span { display: none; }
	}
</style>
