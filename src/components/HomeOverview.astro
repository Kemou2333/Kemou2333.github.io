---
import { Icon } from "astro-icon/components";
import { getCategoryList } from "../utils/content-utils";
import { url } from "../utils/url-utils";

interface Props {
	total: number;
}

const { total } = Astro.props;
const categoryCount = (await getCategoryList()).length;
---

<section class="home-overview card-base onload-animation" aria-labelledby="home-overview-title">
	<div class="home-overview-copy">
		<p>KEMOU / HOME</p>
		<h1 id="home-overview-title">最近更新</h1>
		<div class="home-overview-stats" aria-label="博客统计">
			<span><b>{total}</b> 篇记录</span>
			<i aria-hidden="true"></i>
			<span><b>{categoryCount}</b> 个分类</span>
		</div>
	</div>

	<nav class="home-overview-actions" aria-label="首页快捷入口">
		<a class="home-action" style="--action-accent: var(--accent-cyan)" href={url("/about/")}>
			<span class="home-action-well"><Icon name="fa6-regular:address-card" /></span>
			<span class="home-action-label">关于</span>
		</a>
		<a class="home-action" style="--action-accent: var(--primary)" href={url("/archive/")}>
			<span class="home-action-well"><Icon name="material-symbols:inventory-2-outline-rounded" /></span>
			<span class="home-action-label">归档</span>
		</a>
		<a class="home-action" style="--action-accent: var(--accent-coral)" href={url("/rss.xml")} target="_blank">
			<span class="home-action-well"><Icon name="fa6-solid:rss" /></span>
			<span class="home-action-label">RSS</span>
		</a>
		<a class="home-action" style="--action-accent: var(--accent-mint)" href="https://github.com/Kemou2333" target="_blank" rel="me noreferrer">
			<span class="home-action-well"><Icon name="fa6-brands:github" /></span>
			<span class="home-action-label">GitHub</span>
		</a>
	</nav>
</section>

<style>
	.home-overview {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 9.25rem;
		margin-bottom: 1.25rem;
		padding: 1.3rem 1.45rem;
		overflow: visible;
		isolation: isolate;
	}

	.home-overview::after {
		content: "";
		position: absolute;
		z-index: -1;
		left: 2.5rem;
		bottom: 1.2rem;
		width: 8rem;
		height: 4rem;
		border-radius: 50%;
		background: color-mix(in srgb, var(--accent-cyan) 12%, transparent);
		filter: blur(1.75rem);
		pointer-events: none;
	}

	.home-overview-copy p {
		margin: 0 0 0.25rem;
		font-size: 0.65rem;
		font-weight: 850;
		letter-spacing: 0.17em;
		color: var(--primary);
	}

	.home-overview-copy h1 {
		margin: 0;
		font-size: clamp(1.75rem, 4vw, 2.35rem);
		font-weight: 850;
		line-height: 1.1;
		letter-spacing: -0.035em;
		color: var(--surface-text);
	}

	.home-overview-stats {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		margin-top: 0.8rem;
		padding: 0.45rem 0.7rem;
		border: 1px solid color-mix(in srgb, var(--neu-border) 62%, transparent);
		border-radius: 0.8rem;
		font-size: 0.72rem;
		font-weight: 650;
		color: color-mix(in srgb, var(--surface-text) 58%, transparent);
		background: var(--surface-low);
		box-shadow: inset 3px 3px 7px var(--neu-inset-shadow), inset -3px -3px 7px var(--neu-inset-highlight);
	}

	.home-overview-stats b {
		color: var(--surface-text);
	}

	.home-overview-stats i {
		width: 0.3rem;
		aspect-ratio: 1;
		border-radius: 50%;
		background: var(--accent-mint);
		box-shadow: 0 0 0 0.2rem color-mix(in srgb, var(--accent-mint) 13%, transparent);
	}

	.home-overview-actions {
		display: flex;
		gap: 0.8rem;
	}

	.home-action {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		width: 4.75rem;
		min-height: 5rem;
		padding: 0.45rem;
		border: 1px solid var(--neu-border);
		border-radius: 1.25rem;
		color: var(--action-accent);
		background: linear-gradient(145deg, var(--surface-high), var(--card-bg));
		box-shadow: 7px 7px 15px var(--neu-shadow), -6px -6px 13px var(--neu-highlight), inset 1px 1px 1px var(--neu-highlight-strong);
		transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 200ms ease;
	}

	.home-action-well {
		display: grid;
		place-items: center;
		width: 2.45rem;
		aspect-ratio: 1;
		border-radius: 50%;
		background: var(--surface-low);
		box-shadow: inset 4px 4px 8px var(--neu-inset-shadow), inset -4px -4px 8px var(--neu-inset-highlight);
	}

	.home-action-well :global(svg) {
		width: 1.22rem;
		height: 1.22rem;
	}

	.home-action-label {
		margin-top: 0.35rem;
		font-size: 0.67rem;
		font-weight: 800;
		color: color-mix(in srgb, var(--surface-text) 70%, transparent);
	}

	.home-action:hover,
	.home-action:focus-visible {
		transform: translateY(-3px);
		box-shadow: 10px 10px 20px var(--neu-shadow-strong), -8px -8px 17px var(--neu-highlight-strong), inset 1px 1px 1px var(--neu-highlight-strong);
	}

	.home-action:active {
		transform: translateY(1px);
		box-shadow: inset 5px 5px 10px var(--neu-inset-shadow), inset -5px -5px 10px var(--neu-inset-highlight);
	}

	@media (max-width: 640px) {
		.home-overview {
			min-height: 8rem;
			flex-direction: column;
			align-items: stretch;
			gap: 1.15rem;
			padding: 1.15rem;
		}

		.home-overview-actions {
			display: grid;
			grid-template-columns: repeat(4, minmax(0, 1fr));
			gap: 0.55rem;
		}

		.home-action {
			width: 100%;
			min-height: 4rem;
			border-radius: 1rem;
		}

		.home-action-label {
			display: none;
		}
	}
</style>
