---
import { Icon } from "astro-icon/components";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div class="back-to-top-wrapper hidden lg:block">
    <div id="back-to-top-btn" class="back-to-top-btn hide" onclick="backToTop()">
        <button aria-label="Back to Top" class="back-to-top-surface">
            <Icon name="material-symbols:keyboard-arrow-up-rounded" class="back-to-top-icon"></Icon>
        </button>
    </div>
</div>

<style lang="stylus">
.back-to-top-wrapper
    pointer-events: none

.back-to-top-btn
    position: fixed
    right: 1.25rem
    bottom: 7rem
    width: 3.75rem
    height: 3.75rem
    opacity: 1
    cursor: pointer
    transform: translateY(0) scale(1)
    pointer-events: auto
    transition: opacity 200ms ease, transform 200ms cubic-bezier(0.22, 1, 0.36, 1)
    &.hide
        transform: translateY(1rem) scale(0.88)
        opacity: 0
        pointer-events: none

.back-to-top-surface
    width: 100%
    height: 100%
    display: grid
    place-items: center
    border: 1px solid var(--neu-border)
    border-radius: 50%
    color: var(--primary)
    background: var(--card-bg)
    backdrop-filter: blur(12px)
    box-shadow: 7px 7px 15px var(--neu-shadow), -6px -6px 13px var(--neu-highlight), inset 1px 1px 0 var(--neu-inset-highlight)
    transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 200ms ease, background-color 200ms ease
    &:hover
        transform: translateY(-3px) scale(1.025)
        box-shadow: 10px 10px 20px var(--neu-shadow-strong), -7px -7px 15px var(--neu-highlight-strong), inset 1px 1px 0 var(--neu-inset-highlight)
    &:active
        transform: translateY(1px) scale(0.99)
        box-shadow: inset 5px 5px 10px var(--neu-inset-shadow), inset -5px -5px 10px var(--neu-inset-highlight)

.back-to-top-icon
    display: block
    width: 2rem
    height: 2rem

</style>

<script is:raw is:inline>
function backToTop() {
    window.scroll({ top: 0, behavior: 'smooth' });
}
</script>
